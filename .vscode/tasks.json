{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure QuizApp",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B",
                "build",
                "-S",
                ".",
                "-DCMAKE_TOOLCHAIN_FILE=${env:VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "-DCMAKE_BUILD_TYPE=Release"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Build QuizApp",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "Configure QuizApp",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Run QuizApp",
            "type": "shell",
            "command": ".\\build\\QuizApp.exe",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "Build QuizApp",
            "problemMatcher": []
        }
    ]
}
